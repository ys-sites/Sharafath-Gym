# MEAL ANALYSIS AI PROVIDERS
# At least one of these three keys is required for /api/analyze-meal to work.
# Priority when AI_MEAL_PROVIDER is unset: OPENAI_API_KEY > ANTHROPIC_API_KEY > GEMINI_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI_MEAL_PROVIDER: optional — force meal analysis to a specific provider
# ("openai" | "anthropic" | "gemini"). Leave unset to use key-priority fallback.
AI_MEAL_PROVIDER=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE CONFIGURATION
# You need a Supabase project to persist data. Get these from your Supabase dashboard.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# OWNER CREDENTIALS
# server-side only, never VITE_ prefixed — used by /api/session to mint the app's session
OWNER_EMAIL=
OWNER_PASSWORD=
